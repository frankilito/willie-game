#!/bin/bash
# 汽船威利：黄金汽笛失窃记 —— 双击启动
cd "$(dirname "$0")"
PORT=8961
echo "============================================"
echo "  汽船威利：黄金汽笛失窃记"
echo "  浏览器打开 http://127.0.0.1:$PORT/"
echo "  关闭本窗口即停止服务器"
echo "============================================"
# 自动打开浏览器（macOS）
(sleep 1.2 && open "http://127.0.0.1:$PORT/") &
python3 -m http.server $PORT
